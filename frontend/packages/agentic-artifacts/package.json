{
  "name": "agentic-artifacts",
  "version": "0.1.0",
  "description": "Artifact management extension for Agentic IDE",
  "license": "MIT",
  "keywords": [
    "theia-extension",
    "artifacts",
    "storage"
  ],
  "files": [
    "lib",
    "src"
  ],
  "main": "lib/browser/agentic-artifacts-frontend-module",
  "types": "lib/browser/agentic-artifacts-frontend-module.d.ts",
  "dependencies": {
    "@theia/core": "1.47.0",
    "agentic-core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "rimraf": "^5.0.0",
    "typescript": "~5.0.4"
  },
  "scripts": {
    "prepare": "yarn build",
    "build": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/agentic-artifacts-frontend-module"
    }
  ]
}
