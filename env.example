# Agentic Assistants Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# =============================================================================
# MLFLOW CONFIGURATION
# =============================================================================
# Set to false to disable MLFlow tracking at runtime
AGENTIC_MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=agentic-experiments

# =============================================================================
# OPENTELEMETRY CONFIGURATION
# =============================================================================
AGENTIC_TELEMETRY_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentic-assistants

# Jaeger UI (for viewing traces)
JAEGER_UI_URL=http://localhost:16686

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AGENTIC_LOG_LEVEL=INFO

# Data directory for local storage
AGENTIC_DATA_DIR=./data

# =============================================================================
# LLM PROVIDER CONFIGURATION (for non-Ollama providers)
# =============================================================================
# Uncomment and set if using OpenAI
# OPENAI_API_KEY=your-api-key-here

# Uncomment and set if using Anthropic
# ANTHROPIC_API_KEY=your-api-key-here

# =============================================================================
# KUBERNETES CLUSTER CONFIGURATION
# =============================================================================
# Enable Kubernetes integration
K8S_ENABLED=false

# Path to kubeconfig file (leave empty to auto-discover rpi_kubernetes or use ~/.kube/config)
# Auto-discovery will search for rpi_kubernetes/kubeconfig.yaml
# K8S_KUBECONFIG_PATH=

# Kubernetes context to use (leave empty for current context or "default" for rpi cluster)
# K8S_CONTEXT=default

# Default namespace for agent/flow deployments
K8S_DEFAULT_DEPLOY_NAMESPACE=agentic-workloads

# Namespace for LLM model deployments
K8S_MODEL_SERVING_NAMESPACE=model-serving

# Alternative: Direct cluster connection (instead of kubeconfig)
# K8S_CLUSTER_ENDPOINT=https://192.168.1.100:6443
# K8S_CLUSTER_TOKEN=your-service-account-token

# SSL verification for cluster connections
K8S_VERIFY_SSL=true

# Auto-detection and debugging settings
K8S_AUTODETECT_ENABLED=true
# K8S_AUTODETECT_EXTRA_PATHS=/path/to/kubeconfig1,/path/to/kubeconfig2
K8S_REQUEST_TIMEOUT_SECONDS=10
K8S_INSECURE_SKIP_TLS_VERIFY=false
# K8S_PREFER_INCLUSTER=auto  # auto-detects if running in cluster, or set true/false

# =============================================================================
# MINIO/S3 OBJECT STORAGE CONFIGURATION
# =============================================================================
# Enable MinIO integration (enabled by default, set to false to disable)
# Note: You can also configure connections in the UI Settings > Kubernetes > MinIO Storage
MINIO_ENABLED=true

# MinIO server endpoint (internal cluster address for rpi_kubernetes cluster)
MINIO_ENDPOINT=minio.data-services.svc.cluster.local:9000

# External MinIO endpoint (for access outside cluster)
# MINIO_EXTERNAL_ENDPOINT=minio.example.com:9000

# MinIO credentials (default placeholders for rpi_kubernetes cluster)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Use HTTPS for MinIO connections
MINIO_SECURE=false

# Default bucket for artifacts
MINIO_DEFAULT_BUCKET=agentic-artifacts

# Bucket for model cache
MINIO_MODEL_BUCKET=model-cache

# =============================================================================
# POSTGRESQL DATABASE CONFIGURATION
# =============================================================================
# Enable PostgreSQL database integration
POSTGRES_ENABLED=false

# PostgreSQL connection (defaults for rpi_kubernetes cluster)
POSTGRES_HOST=postgresql.data-services.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DATABASE=mlflow
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow123

# Alternative: Full connection string (overrides individual settings)
# POSTGRES_CONNECTION_STRING=postgresql://user:pass@host:port/dbname

# =============================================================================
# MLFLOW CONFIGURATION (updated for cluster integration)
# =============================================================================
# MLFlow tracking URI (defaults to cluster service if available)
# For rpi_kubernetes cluster, use: http://mlflow.ml-platform.svc.cluster.local:5000
# MLFLOW_TRACKING_URI=http://mlflow.ml-platform.svc.cluster.local:5000

# MLFlow backend store URI (PostgreSQL - will use POSTGRES_* settings if enabled)
# MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow123@postgresql.data-services.svc.cluster.local:5432/mlflow

# MLFlow S3 artifact store (MinIO - will use MINIO_* settings if enabled)
# MLFLOW_S3_ENDPOINT_URL=http://minio.data-services.svc.cluster.local:9000
# MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts/