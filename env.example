# Agentic Assistants Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# =============================================================================
# MLFLOW CONFIGURATION
# =============================================================================
# Set to false to disable MLFlow tracking at runtime
AGENTIC_MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=agentic-experiments

# =============================================================================
# OPENTELEMETRY CONFIGURATION
# =============================================================================
AGENTIC_TELEMETRY_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentic-assistants

# Jaeger UI (for viewing traces)
JAEGER_UI_URL=http://localhost:16686

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AGENTIC_LOG_LEVEL=INFO

# Data directory for local storage
AGENTIC_DATA_DIR=./data

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TESTING_ENABLED=true
TESTING_SANDBOX_DEFAULT=true
TESTING_TRACKING_DEFAULT=false
TESTING_AGENT_EVAL_DEFAULT=false
TESTING_RL_METRICS_DEFAULT=false
TESTING_TIMEOUT_SECONDS=60
TESTING_DATASET_SAMPLE_SIZE=25
TESTING_MAX_OUTPUT_CHARS=8000

# =============================================================================
# HUGGINGFACE CONFIGURATION
# =============================================================================
# HuggingFace Hub token (for private repos, gated models, and push operations)
# HF_TOKEN=hf_your_token_here

# HuggingFace Inference API key (for remote embedding/inference endpoints)
# This is separate from HF_TOKEN -- HF_TOKEN is for Hub access, HF_API_KEY
# is for the serverless Inference API.
# HF_API_KEY=hf_your_inference_api_key_here

# Local cache directories
HF_CACHE_DIR=./data/models/hf_cache
HF_DATASETS_CACHE_DIR=./data/datasets/hf_cache

# Default organization for push operations
# HF_DEFAULT_ORG=your-org

# Offline mode (disable all Hub requests)
HF_OFFLINE_MODE=false

# Enable paper search
HF_PAPERS_ENABLED=true

# =============================================================================
# PYTORCH CONFIGURATION
# =============================================================================
# Force a specific device (cuda, mps, cpu). Leave unset for auto-detection.
# TORCH_DEVICE=cuda

# =============================================================================
# GENERIC LLM PROVIDER CONFIGURATION (assistant + engine + eval flows)
# =============================================================================
# Active provider: ollama | huggingface_local | openai_compatible
LLM_PROVIDER=ollama

# Default model used by provider-aware chat paths
# LLM_MODEL=llama3.2

# Shared timeout in seconds
LLM_TIMEOUT=120

# Optional provider-specific endpoint override
# LLM_OLLAMA_HOST=http://localhost:11434
LLM_OPENAI_BASE_URL=http://localhost:8000/v1
LLM_OPENAI_API_KEY_ENV=OPENAI_API_KEY

# Hugging Face local runtime defaults
LLM_HF_EXECUTION_MODE=hybrid
# LLM_HF_LOCAL_MODEL=meta-llama/Llama-3.2-3B-Instruct
LLM_HF_DEVICE_MAP=auto
# LLM_HF_TORCH_DTYPE=float16
LLM_HF_TRUST_REMOTE_CODE=false

# Optional fallback provider if primary fails
# LLM_FALLBACK_PROVIDER=ollama

# Provider credentials
# OPENAI_API_KEY=your-api-key-here
# OPENROUTER_API_KEY=your-api-key-here

# =============================================================================
# ASSISTANT-SPECIFIC LLM DEFAULTS
# =============================================================================
ASSISTANT_PROVIDER=ollama
# ASSISTANT_ENDPOINT=http://localhost:11434
ASSISTANT_OPENAI_API_KEY_ENV=OPENAI_API_KEY
ASSISTANT_HF_EXECUTION_MODE=hybrid

# =============================================================================
# TESTING / EVALUATION LLM DEFAULTS
# =============================================================================
# TESTING_EVAL_PROVIDER=ollama
# TESTING_EVAL_MODEL=llama3.2
# TESTING_EVAL_ENDPOINT=http://localhost:11434
TESTING_EVAL_HF_EXECUTION_MODE=hybrid

# =============================================================================
# JUPYTER NOTEBOOK SERVER CONFIGURATION
# =============================================================================
# Enable managed notebook server (auto-starts with backend)
JUPYTER_ENABLED=true

# Server bind address and port
JUPYTER_HOST=127.0.0.1
JUPYTER_PORT=8888

# Root directory for notebooks
JUPYTER_NOTEBOOK_DIR=./notebooks

# Auth token (empty = no auth, suitable for local dev)
# JUPYTER_TOKEN=

# Kernel name registered for the framework environment
JUPYTER_KERNEL_NAME=agentic

# For production: point to Kubernetes JupyterHub and disable local server
# JUPYTER_EXTERNAL_URL=https://jupyterhub.cluster.local

# =============================================================================
# KUBERNETES CLUSTER CONFIGURATION
# =============================================================================
# Enable Kubernetes integration
K8S_ENABLED=false

# Path to kubeconfig file (leave empty to auto-discover rpi_kubernetes or use ~/.kube/config)
# Auto-discovery will search for rpi_kubernetes/kubeconfig.yaml
# K8S_KUBECONFIG_PATH=

# Kubernetes context to use (leave empty for current context or "default" for rpi cluster)
# K8S_CONTEXT=default

# Default namespace for agent/flow deployments
K8S_DEFAULT_DEPLOY_NAMESPACE=agentic-workloads

# Namespace for LLM model deployments
K8S_MODEL_SERVING_NAMESPACE=model-serving

# Alternative: Direct cluster connection (instead of kubeconfig)
# K8S_CLUSTER_ENDPOINT=https://192.168.1.100:6443
# K8S_CLUSTER_TOKEN=your-service-account-token

# SSL verification for cluster connections
K8S_VERIFY_SSL=true

# Auto-detection and debugging settings
K8S_AUTODETECT_ENABLED=true
# K8S_AUTODETECT_EXTRA_PATHS=/path/to/kubeconfig1,/path/to/kubeconfig2
K8S_REQUEST_TIMEOUT_SECONDS=10
K8S_INSECURE_SKIP_TLS_VERIFY=false
# K8S_PREFER_INCLUSTER=auto  # auto-detects if running in cluster, or set true/false

# =============================================================================
# MINIO/S3 OBJECT STORAGE CONFIGURATION
# =============================================================================
# Enable MinIO integration (enabled by default, set to false to disable)
# Note: You can also configure connections in the UI Settings > Kubernetes > MinIO Storage
MINIO_ENABLED=true

# MinIO server endpoint (internal cluster address for rpi_kubernetes cluster)
MINIO_ENDPOINT=minio.data-services.svc.cluster.local:9000

# External MinIO endpoint (for access outside cluster)
# MINIO_EXTERNAL_ENDPOINT=minio.example.com:9000

# MinIO credentials (default placeholders for rpi_kubernetes cluster)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Use HTTPS for MinIO connections
MINIO_SECURE=false

# Default bucket for artifacts
MINIO_DEFAULT_BUCKET=agentic-artifacts

# Bucket for model cache
MINIO_MODEL_BUCKET=model-cache

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database type: sqlite, postgres, supabase
DATABASE_TYPE=sqlite

# Automatic migrations on startup
DATABASE_AUTO_MIGRATE=true

# Database backups
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_INTERVAL_HOURS=24
DATABASE_BACKUP_RETENTION_DAYS=7

# =============================================================================
# POSTGRESQL DATABASE CONFIGURATION
# =============================================================================
# Enable PostgreSQL database integration
POSTGRES_ENABLED=false

# PostgreSQL connection (defaults for rpi_kubernetes cluster)
POSTGRES_HOST=postgresql.data-services.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DATABASE=mlflow
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow123

# Connection pool settings
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30

# Alternative: Full connection string (overrides individual settings)
# POSTGRES_CONNECTION_STRING=postgresql://user:pass@host:port/dbname

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Enable Supabase integration
SUPABASE_ENABLED=false

# Supabase project URL and keys
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key

# JWT secret for token verification
# SUPABASE_JWT_SECRET=your-jwt-secret

# Enable realtime subscriptions
SUPABASE_REALTIME_ENABLED=true

# Auto-refresh tokens
SUPABASE_AUTO_REFRESH_TOKEN=true

# =============================================================================
# MLFLOW CONFIGURATION (updated for cluster integration)
# =============================================================================
# MLFlow tracking URI (defaults to cluster service if available)
# For rpi_kubernetes cluster, use: http://mlflow.ml-platform.svc.cluster.local:5000
# MLFLOW_TRACKING_URI=http://mlflow.ml-platform.svc.cluster.local:5000

# MLFlow backend store URI (PostgreSQL - will use POSTGRES_* settings if enabled)
# MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow123@postgresql.data-services.svc.cluster.local:5432/mlflow

# MLFlow S3 artifact store (MinIO - will use MINIO_* settings if enabled)
# MLFLOW_S3_ENDPOINT_URL=http://minio.data-services.svc.cluster.local:9000
# MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts/

# =============================================================================
# PREFECT ORCHESTRATION CONFIGURATION
# =============================================================================
# Enable Prefect integration
# PREFECT_API_URL=http://localhost:4200/api
# PREFECT_API_KEY=your-prefect-cloud-api-key

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Enable Redis cache
REDIS_ENABLED=false

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-redis-password
REDIS_PREFIX=agentic:

# TTL settings (in seconds)
REDIS_DEFAULT_TTL=3600
REDIS_SOLUTION_CACHE_TTL=86400
REDIS_EMBEDDING_CACHE_TTL=604800

# =============================================================================
# DATA SYNCHRONIZATION CONFIGURATION
# =============================================================================
# Sync strategy: last-write-wins, vector-clock, manual
# SYNC_STRATEGY=last-write-wins

# Sync interval (in seconds)
# SYNC_INTERVAL=300

# =============================================================================
# WEB SCRAPING AND INTEGRATIONS
# =============================================================================
# Firecrawl API key (for advanced web scraping)
# FIRECRAWL_API_KEY=your-api-key

# Composio API key (for tool integrations)
# COMPOSIO_API_KEY=your-api-key

# =============================================================================
# DATAHUB CONFIGURATION
# =============================================================================
# Enable DataHub data catalog integration
DATAHUB_ENABLED=false

# DataHub GMS REST API endpoint
DATAHUB_GMS_URL=http://localhost:8080

# DataHub frontend URL (for external links in the WebUI)
DATAHUB_FRONTEND_URL=http://datahub.local

# DataHub personal access token (for API authentication)
# DATAHUB_TOKEN=

# Enable Iceberg catalog features via DataHub GMS
DATAHUB_ICEBERG_ENABLED=true

# =============================================================================
# ICEBERG CONFIGURATION
# =============================================================================
# Iceberg REST catalog endpoint (DataHub GMS /iceberg path)
ICEBERG_CATALOG_URI=http://localhost:8080/iceberg

# Default warehouse location in S3/MinIO
ICEBERG_WAREHOUSE=s3://iceberg-warehouse/

# S3-compatible endpoint (MinIO)
ICEBERG_S3_ENDPOINT=http://localhost:9000

# S3 credentials
ICEBERG_S3_ACCESS_KEY=minioadmin
ICEBERG_S3_SECRET_KEY=minioadmin123

# =============================================================================
# DBT CONFIGURATION
# =============================================================================
# Enable dbt integration
DBT_ENABLED=false

# Path to the dbt project directory
# DBT_PROJECT_DIR=./src/agentic_assistants/dbt

# Path to the dbt profiles directory
# DBT_PROFILES_DIR=./src/agentic_assistants/dbt

# dbt target profile
DBT_TARGET=dev

# PostgreSQL connection for dbt
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5432
DBT_POSTGRES_DATABASE=agentic
DBT_POSTGRES_USER=postgres
DBT_POSTGRES_PASSWORD=postgres123

# =============================================================================
# NEMOTRON MODEL CONFIGURATION
# =============================================================================
# Default model from HuggingFace Hub
NEMOTRON_DEFAULT_MODEL=nvidia/Llama-3.1-Nemotron-Nano-8B-v1

# Local cache for Nemotron weights
NEMOTRON_CACHE_DIR=./data/models/nemotron

# Serving backend: ollama, vllm, tgi
NEMOTRON_SERVING_BACKEND=ollama

# URL of running Nemotron serving endpoint (auto-detected if not set)
# NEMOTRON_SERVING_URL=http://localhost:11434

# Default quantization: none, int8, int4, gptq, awq
NEMOTRON_QUANTIZATION=none

# Trust remote code from HuggingFace
NEMOTRON_TRUST_REMOTE_CODE=true