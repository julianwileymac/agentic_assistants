{
  "jupyter.lab.setting-icon": "mlflow:logo",
  "jupyter.lab.setting-icon-label": "MLFlow",
  "title": "MLFlow",
  "description": "MLFlow experiment management settings",
  "type": "object",
  "properties": {
    "backendUrl": {
      "type": "string",
      "default": "http://localhost:8080",
      "title": "Backend URL",
      "description": "URL of the Agentic backend API server"
    },
    "mlflowUIUrl": {
      "type": "string",
      "default": "http://localhost:5000",
      "title": "MLFlow UI URL",
      "description": "URL of the MLFlow tracking UI"
    },
    "pollInterval": {
      "type": "number",
      "default": 30000,
      "title": "Poll Interval",
      "description": "Interval in milliseconds to poll for updates"
    },
    "autoRefresh": {
      "type": "boolean",
      "default": true,
      "title": "Auto Refresh",
      "description": "Automatically refresh experiments list"
    }
  },
  "additionalProperties": false
}

