# Dagster services Dockerfile
# Supports webserver, daemon, and code server via different CMD overrides

FROM python:3.11-slim AS base

WORKDIR /app
ENV PYTHONPATH=/app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Dagster and extensions
RUN pip install --no-cache-dir \
    dagster \
    dagster-webserver \
    dagster-postgres \
    dagster-k8s \
    dagster-docker

# Install framework dependencies required by code location
COPY pyproject.toml poetry.lock* ./
RUN pip install --no-cache-dir poetry && \
    poetry config virtualenvs.create false && \
    poetry install --no-interaction --no-root --only main 2>/dev/null || true

# Copy application source
COPY src/ ./src/

# Install the package
RUN pip install --no-cache-dir -e .

# Templates copied into the image; entrypoint seeds $DAGSTER_HOME when using a
# named volume (which otherwise hides these files and leaves the UI unreachable).
RUN mkdir -p /opt/dagster/dagster_home /opt/dagster/dagster_config_templates

COPY conf/base/dagster.yaml /opt/dagster/dagster_config_templates/dagster.yaml
COPY conf/docker/workspace.yaml /opt/dagster/dagster_config_templates/workspace.yaml

COPY docker/dagster-entrypoint.sh /dagster-entrypoint.sh
RUN sed -i 's/\r$//' /dagster-entrypoint.sh && chmod +x /dagster-entrypoint.sh

ENV DAGSTER_HOME=/opt/dagster/dagster_home
ENV DAGSTER_TEMPLATE_DIR=/opt/dagster/dagster_config_templates

ENTRYPOINT ["/dagster-entrypoint.sh"]

# No image-level HEALTHCHECK: this image runs webserver, daemon, and gRPC code
# server; only the webserver listens on :3000. Use compose-level checks per service.

# Default: run the webserver with explicit workspace path
EXPOSE 3000
CMD ["dagster-webserver", "-h", "0.0.0.0", "-p", "3000", "-w", "/opt/dagster/dagster_home/workspace.yaml"]
